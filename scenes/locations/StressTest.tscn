[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/locations/StressTest.gd" id="1"]

[node name="StressTest" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="ColorBackground" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.06, 0.12, 1)

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 48
theme_override_constants/margin_top = 48
theme_override_constants/margin_right = 48
theme_override_constants/margin_bottom = 48

[node name="VBox" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="MarginContainer/VBox"]
layout_mode = 2
text = "Stress Test (stub)"
theme_override_font_sizes/font_size = 36

[node name="Blurb" type="Label" parent="MarginContainer/VBox"]
layout_mode = 2
text = "Simulate the outcome. The real timed minigame replaces this scene later."
autowrap_mode = 2
theme_override_font_sizes/font_size = 16

[node name="InfoLabel" type="Label" parent="MarginContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Equipped limbs: 0  |  Current anger: 0  |  Tonight's wakes: 0"
theme_override_font_sizes/font_size = 14

[node name="Spacer" type="Control" parent="MarginContainer/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="Buttons" type="VBoxContainer" parent="MarginContainer/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Good" type="Button" parent="MarginContainer/VBox/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(320, 48)
text = "Good stress-test (anger −20)"

[node name="Bad" type="Button" parent="MarginContainer/VBox/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(320, 48)
text = "Bad stress-test (anger −5)"

[node name="Recorded" type="Button" parent="MarginContainer/VBox/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(320, 48)
text = "Record run (+40 money, +6 suspicion, anger −10)"

[node name="Wake" type="Button" parent="MarginContainer/VBox/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(320, 48)
text = "Wake the robot (retry — adds fail-penalty at day end)"

[node name="GiveUp" type="Button" parent="MarginContainer/VBox/Buttons"]
layout_mode = 2
custom_minimum_size = Vector2(320, 48)
text = "Give up for tonight (advance to next day)"

[connection signal="pressed" from="MarginContainer/VBox/Buttons/Good" to="." method="_on_good_pressed"]
[connection signal="pressed" from="MarginContainer/VBox/Buttons/Bad" to="." method="_on_bad_pressed"]
[connection signal="pressed" from="MarginContainer/VBox/Buttons/Recorded" to="." method="_on_recorded_pressed"]
[connection signal="pressed" from="MarginContainer/VBox/Buttons/Wake" to="." method="_on_wake_pressed"]
[connection signal="pressed" from="MarginContainer/VBox/Buttons/GiveUp" to="." method="_on_give_up_pressed"]
